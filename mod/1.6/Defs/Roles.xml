  <WorkRoles.RoleDef>
    <defName>WS_Smith</defName>
    <label>Smith</label>
    <description>Weapon and armor smithing.</description>
    <colorRef>amber-700</colorRef>
    <group>Indoors</group>
    <trainSkill>Crafting</trainSkill>
