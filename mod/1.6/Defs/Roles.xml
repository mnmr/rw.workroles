  <WorkRoles.RoleDef MayRequire="Ludeon.RimWorld.Odyssey">
    <defName>WS_Fisher</defName>
    <label>Fisher</label>
    <description>Fishing.</description>
    <colorRef>teal-800</colorRef>
    <group>Animals</group>
    <minHolders>0</minHolders>
    <entries>
      <li>WorkType:Fishing</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Builder</defName>
    <label>Builder</label>
    <description>Construction, repair and deconstruction.</description>
    <colorRef>yellow-700</colorRef>
    <group>Indoors</group>
    <trainSkill>Construction</trainSkill>
    <trainMinLevel>8</trainMinLevel>
    <minHolders>1</minHolders>
    <entries>
      <li>WorkType:Construction</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Repairer</defName>
    <label>Handyman</label>
    <description>All construction work except constructing new buildings.</description>
    <colorRef>yellow-800</colorRef>
    <group>Indoors</group>
    <trainSkill>Construction</trainSkill>
    <trainMaxLevel>8</trainMaxLevel>
    <trainTargets><li>WS_Builder</li></trainTargets>
    <minHolders>0</minHolders>
    <entries>
      <li>WorkGiver:Repair</li>
      <li>WorkGiver:FixBrokenDownBuilding</li>
      <li>WorkGiver:Deconstruct</li>
      <li>WorkGiver:DeconstructForBlueprint</li>
      <li>WorkGiver:Uninstall</li>
      <li>WorkGiver:FillIn</li>
      <li>WorkGiver:ConstructRemoveFloors</li>
      <li>WorkGiver:ConstructRemoveFoundations</li>
      <li>WorkGiver:BuildRoofs</li>
      <li>WorkGiver:RemoveRoofs</li>
      <li>WorkGiver:ConstructDeliverResourcesToFrames</li>
      <li>WorkGiver:ConstructDeliverResourcesToBlueprints</li>
      <li>WorkGiver:ConstructSmoothWalls</li>
      <li>WorkGiver:ConstructSmoothFloors</li>
    </entries>
