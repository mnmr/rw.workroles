<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Role-list groups, in display order. -->
  <WorkRoles.RoleGroupDef><defName>WS_GroupEssentials</defName><label>Essentials</label><order>1</order></WorkRoles.RoleGroupDef>
  <WorkRoles.RoleGroupDef><defName>WS_GroupAnimals</defName><label>Animals</label><order>2</order></WorkRoles.RoleGroupDef>
  <WorkRoles.RoleGroupDef><defName>WS_GroupPlants</defName><label>Plants</label><order>3</order></WorkRoles.RoleGroupDef>
  <WorkRoles.RoleGroupDef><defName>WS_GroupIndoors</defName><label>Indoors</label><order>4</order></WorkRoles.RoleGroupDef>
  <WorkRoles.RoleGroupDef><defName>WS_GroupOutdoors</defName><label>Outdoors</label><order>5</order></WorkRoles.RoleGroupDef>
  <WorkRoles.RoleGroupDef><defName>WS_GroupFood</defName><label>Food</label><order>6</order></WorkRoles.RoleGroupDef>
  <WorkRoles.RoleGroupDef><defName>WS_GroupResearch</defName><label>Research</label><order>7</order></WorkRoles.RoleGroupDef>

  <WorkRoles.RoleDef>
    <defName>WS_NoFirefighting</defName>
    <label>Pyrophobe</label>
    <description>Blocker: colonists holding this role never fight fires, even when a later role (like Basics) includes firefighting.</description>
    <blocker>true</blocker>
    <colorRef>rose-800</colorRef>
    <group>Essentials</group>
    <entries>
      <li>WorkType:Firefighter</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Core</defName>
    <label>Core</label>
    <description>Emergency work every colonist must do: firefighting, being treated and rescuing.</description>
    <autoAssign>true</autoAssign>
    <colorRef>slate-700</colorRef>
    <group>Essentials</group>
    <entries>
      <li>WorkType:Firefighter</li>
      <li>WorkType:Patient</li>
      <li>WorkGiver:DoctorRescue</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Basics</defName>
    <label>Basics</label>
    <description>Self-care and simple work every colonist should do.</description>
    <autoAssign>true</autoAssign>
    <colorRef>slate-600</colorRef>
    <group>Essentials</group>
    <!-- Sits below Doctor in vanilla's grid (bed rest 1200 vs doctoring 1300),
         so emergencies (Core) rank above doctoring and this below. Allow Tool's
         urgent hauling is appended here at seed time (Seeding.EveryoneWorkTypes). -->
    <entries>
      <li>WorkType:PatientBedRest</li>
      <li>WorkType:BasicWorker</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Rescuer</defName>
    <label>Rescuer</label>
    <description>Rescuing downed colonists.</description>
    <colorRef>slate-800</colorRef>
    <group>Essentials</group>
    <entries>
      <li>WorkGiver:DoctorRescue</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Doctor</defName>
    <label>Doctor</label>
    <description>Medical care for colonists, prisoners and animals.</description>
    <colorRef>red-800</colorRef>
    <group>Essentials</group>
    <trainSkill>Medicine</trainSkill>
    <trainMinLevel>15</trainMinLevel>
    <minHolders>1</minHolders>
    <entries>
      <li>WorkType:Doctor</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Medic</defName>
    <label>Medic</label>
    <description>Medical work except operating on colonists.</description>
    <colorRef>red-900</colorRef>
    <group>Essentials</group>
    <trainSkill>Medicine</trainSkill>
    <trainMinLevel>5</trainMinLevel>
    <trainMaxLevel>15</trainMaxLevel>
    <trainTargets><li>WS_Doctor</li></trainTargets>
    <minHolders>0</minHolders>
    <entries>
      <li>WorkGiver:DoctorTendEmergency</li>
      <li>WorkGiver:DoctorTendToHumanlikes</li>
      <li>WorkGiver:DoctorTendToSelf</li>
      <li>WorkGiver:DoctorTendToSelfEmergency</li>
      <li>WorkGiver:DoctorRescue</li>
      <li>WorkGiver:DoctorFeedHumanlikes</li>
      <li>WorkGiver:DoctorTendToAnimals</li>
      <li>WorkGiver:DoctorFeedAnimals</li>
      <li>WorkGiver:VisitSickPawn</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">WorkGiver:ExtractBioferrite</li>
      <li>WorkGiver:TakeToBedToOperate</li>
      <li MayRequire="Ludeon.RimWorld.Biotech">WorkGiver:FeedHemogen</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">WorkGiver:DoctorTendToEntities</li>
      <li>WorkGiver:DoBillsMedicalAnimalOperation</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Laborer</defName>
    <label>Laborer</label>
    <description>Miscellaneous simple tasks.</description>
    <colorRef>slate-800</colorRef>
    <group>Essentials</group>
    <entries>
      <li>WorkType:BasicWorker</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef MayRequire="Ludeon.RimWorld.Biotech">
    <defName>WS_Childminder</defName>
    <label>Caretaker</label>
    <description>Childcare and teaching.</description>
    <colorRef>cyan-700</colorRef>
    <group>Essentials</group>
    <!-- Needed work only while the colony has children; the adapter zeroes it otherwise. -->
    <minHolders>1</minHolders>
    <entries>
      <li>WorkType:Childcare</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Firefighter</defName>
    <label>Firefighter</label>
    <description>Fighting fires.</description>
    <colorRef>slate-800</colorRef>
    <group>Essentials</group>
    <entries>
      <li>WorkType:Firefighter</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Patient</defName>
    <label>Patient</label>
    <description>Accepting medical treatment.</description>
    <colorRef>slate-800</colorRef>
    <group>Essentials</group>
    <entries>
      <li>WorkType:Patient</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Bedrest</defName>
    <label>Bedrest</label>
    <description>Resting in bed when ill or injured.</description>
    <colorRef>slate-800</colorRef>
    <group>Essentials</group>
    <entries>
      <li>WorkType:PatientBedRest</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Jailor</defName>
    <label>Jailor</label>
    <description>Prisoner handling except interrogation, enslavement and conversion: feeding, escorting, chatting, suppression, release and executions.</description>
    <colorRef>cyan-900</colorRef>
    <group>Essentials</group>
    <trainSkill>Social</trainSkill>
    <trainTargets><li>WS_Warden</li></trainTargets>
    <minHolders>0</minHolders>
    <!-- All Warden givers in vanilla order EXCEPT InterrogatePrisoner,
         EnslavePrisoner and ConvertPrisoner; ChatWithPrisoner trains Social,
         making this a real trainer toward Warden. -->
    <entries>
      <li MayRequire="Ludeon.RimWorld.Anomaly">WorkGiver:ExecuteEntity</li>
      <li>WorkGiver:DoExecution</li>
      <li>WorkGiver:ExecuteGuiltyColonist</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">WorkGiver:ExecuteSlave</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">WorkGiver:EmancipateSlave</li>
      <li>WorkGiver:ReleasePrisoner</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">WorkGiver:ActivitySuppression</li>
      <li>WorkGiver:TakePrisonerToBed</li>
      <li>WorkGiver:FeedPrisoner</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">WorkGiver:ImprisonSlave</li>
      <li MayRequire="Ludeon.RimWorld.Biotech">WorkGiver:DeliverHemogenToPrisoner</li>
      <li>WorkGiver:DeliverFoodToPrisoner</li>
      <li MayRequire="Ludeon.RimWorld.Ideology">WorkGiver:SuppressSlave</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">WorkGiver:ReleaseEntity</li>
      <li>WorkGiver:ChatWithPrisoner</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Warden</defName>
    <label>Warden</label>
    <description>Prisoner interaction: recruitment, conversion, feeding and release.</description>
    <colorRef>cyan-800</colorRef>
    <group>Essentials</group>
    <minHolders>1</minHolders>
    <entries>
      <li>WorkType:Warden</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Grunt</defName>
