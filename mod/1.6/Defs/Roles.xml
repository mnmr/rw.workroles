<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <WorkRoles.RoleDef>
    <defName>WS_Basics</defName>
    <label>Basics</label>
    <description>Emergency and self-care work every colonist should do.</description>
    <autoAssign>true</autoAssign>
    <colorRef>slate-600</colorRef>
    <entries>
      <li>WorkType:Firefighter</li>
      <li>WorkType:Patient</li>
      <li>WorkType:PatientBedRest</li>
      <li>WorkGiver:DoctorRescue</li>
      <li>WorkType:BasicWorker</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Rescuer</defName>
    <label>Rescuer</label>
    <description>Rescuing downed colonists.</description>
    <colorRef>slate-800</colorRef>
    <entries>
      <li>WorkGiver:DoctorRescue</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Doctor</defName>
    <label>Doctor</label>
    <description>Medical care for colonists, prisoners and animals.</description>
    <colorRef>red-800</colorRef>
    <gateSkill>Medicine</gateSkill>
    <gateMinLevel>10</gateMinLevel>
    <entries>
      <li>WorkType:Doctor</li>
      <!-- Redundant at compile time (Doctor already includes them); listed so
           Medic is a literal subset of Doctor. -->
      <li>WorkGiver:DoctorTendEmergency</li>
      <li>WorkGiver:DoctorTendToHumanlikes</li>
      <li>WorkGiver:DoctorTendToSelf</li>
      <li>WorkGiver:DoctorTendToSelfEmergency</li>
      <li>WorkGiver:DoctorRescue</li>
      <li>WorkGiver:DoctorFeedHumanlikes</li>
      <li>WorkGiver:DoctorTendToAnimals</li>
      <li>WorkGiver:DoctorFeedAnimals</li>
      <li>WorkGiver:VisitSickPawn</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_NoFirefighting</defName>
    <label>No Firefighting</label>
    <description>Blocker: colonists holding this role never fight fires, even when a later role (like Basics) includes firefighting.</description>
    <blocker>true</blocker>
    <colorRef>rose-800</colorRef>
    <entries>
      <li>WorkType:Firefighter</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Medic</defName>
    <label>Medic</label>
    <description>Tending, feeding and rescuing patients — no operations.</description>
    <colorRef>red-900</colorRef>
    <gateSkill>Medicine</gateSkill>
    <gateMaxLevel>10</gateMaxLevel>
    <gateNeedsPassion>true</gateNeedsPassion>
    <entries>
      <li>WorkGiver:DoctorTendEmergency</li>
      <li>WorkGiver:DoctorTendToHumanlikes</li>
      <li>WorkGiver:DoctorTendToSelf</li>
      <li>WorkGiver:DoctorTendToSelfEmergency</li>
      <li>WorkGiver:DoctorRescue</li>
      <li>WorkGiver:DoctorFeedHumanlikes</li>
      <li>WorkGiver:DoctorTendToAnimals</li>
      <li>WorkGiver:DoctorFeedAnimals</li>
      <li>WorkGiver:VisitSickPawn</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef MayRequire="Ludeon.RimWorld.Biotech">
    <defName>WS_Childminder</defName>
    <label>Childcare</label>
    <description>Childcare and teaching.</description>
    <colorRef>cyan-800</colorRef>
    <entries>
      <li>WorkType:Childcare</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Warden</defName>
    <label>Warden</label>
    <description>Prisoner interaction: recruitment, conversion, feeding and release.</description>
    <colorRef>cyan-800</colorRef>
    <entries>
      <li>WorkType:Warden</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Handler</defName>
    <label>Handler</label>
    <description>Animal taming, training and slaughter.</description>
    <colorRef>teal-800</colorRef>
    <entries>
      <li>WorkType:Handling</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Cook</defName>
    <label>Cook</label>
    <description>Meal preparation and butchering.</description>
    <colorRef>green-700</colorRef>
    <gateSkill>Cooking</gateSkill>
    <gateMinLevel>8</gateMinLevel>
    <entries>
      <li>WorkType:Cooking</li>
      <!-- Redundant at compile time (Cooking already includes them); listed so
           Butcher and Brewer are literal subsets of Cook. -->
      <li>WorkGiver:DoBillsButcherFlesh</li>
      <li>WorkGiver:DoBillsBrew</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Butcher</defName>
    <label>Butcher</label>
    <description>Butchering creatures.</description>
    <colorRef>green-800</colorRef>
    <gateSkill>Cooking</gateSkill>
    <gateMaxLevel>8</gateMaxLevel>
    <gateNeedsPassion>true</gateNeedsPassion>
    <entries>
      <li>WorkGiver:DoBillsButcherFlesh</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Brewer</defName>
    <label>Brewer</label>
    <description>Brewing wort at the brewery.</description>
    <colorRef>green-800</colorRef>
    <gateSkill>Cooking</gateSkill>
    <gateMaxLevel>8</gateMaxLevel>
    <gateNeedsPassion>true</gateNeedsPassion>
    <entries>
      <li>WorkGiver:DoBillsBrew</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Hunter</defName>
    <label>Hunter</label>
    <description>Hunting wild animals for food.</description>
    <colorRef>teal-700</colorRef>
    <entries>
      <li>WorkType:Hunting</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef MayRequire="Ludeon.RimWorld.Odyssey">
    <defName>WS_Fisher</defName>
    <label>Fisher</label>
    <description>Fishing.</description>
    <colorRef>teal-800</colorRef>
    <entries>
      <li>WorkType:Fishing</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Builder</defName>
    <label>Builder</label>
    <description>Construction, repair and deconstruction.</description>
    <colorRef>yellow-700</colorRef>
    <gateSkill>Construction</gateSkill>
    <gateMinLevel>8</gateMinLevel>
    <entries>
      <li>WorkType:Construction</li>
      <!-- Redundant at compile time (Construction already includes them); listed
           so Handyman is a literal subset of Builder. -->
      <li>WorkGiver:Repair</li>
      <li>WorkGiver:FixBrokenDownBuilding</li>
      <li>WorkGiver:Deconstruct</li>
      <li>WorkGiver:DeconstructForBlueprint</li>
      <li>WorkGiver:Uninstall</li>
      <li>WorkGiver:FillIn</li>
      <li>WorkGiver:ConstructRemoveFloors</li>
      <li>WorkGiver:ConstructRemoveFoundations</li>
      <li>WorkGiver:BuildRoofs</li>
      <li>WorkGiver:RemoveRoofs</li>
      <li>WorkGiver:ConstructDeliverResourcesToFrames</li>
      <li>WorkGiver:ConstructDeliverResourcesToBlueprints</li>
      <li>WorkGiver:ConstructSmoothWalls</li>
      <li>WorkGiver:ConstructSmoothFloors</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Repairer</defName>
    <label>Handyman</label>
    <description>All construction work except constructing new buildings.</description>
    <colorRef>yellow-800</colorRef>
    <gateSkill>Construction</gateSkill>
    <gateMaxLevel>8</gateMaxLevel>
    <gateNeedsPassion>true</gateNeedsPassion>
    <entries>
      <li>WorkGiver:Repair</li>
      <li>WorkGiver:FixBrokenDownBuilding</li>
      <li>WorkGiver:Deconstruct</li>
      <li>WorkGiver:DeconstructForBlueprint</li>
      <li>WorkGiver:Uninstall</li>
      <li>WorkGiver:FillIn</li>
      <li>WorkGiver:ConstructRemoveFloors</li>
      <li>WorkGiver:ConstructRemoveFoundations</li>
      <li>WorkGiver:BuildRoofs</li>
      <li>WorkGiver:RemoveRoofs</li>
      <li>WorkGiver:ConstructDeliverResourcesToFrames</li>
      <li>WorkGiver:ConstructDeliverResourcesToBlueprints</li>
      <li>WorkGiver:ConstructSmoothWalls</li>
      <li>WorkGiver:ConstructSmoothFloors</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Farmer</defName>
    <label>Farmer</label>
    <description>Sowing, harvesting and plant cutting.</description>
    <colorRef>lime-700</colorRef>
    <entries>
      <li>WorkType:Growing</li>
      <li>WorkType:PlantCutting</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Grower</defName>
    <label>Grower</label>
    <description>Sowing and harvesting in growing zones.</description>
    <colorRef>lime-800</colorRef>
    <entries>
      <li>WorkType:Growing</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_PlantCutter</defName>
    <label>Plant Cutter</label>
    <description>Cutting and harvesting wild plants and trees.</description>
    <colorRef>lime-800</colorRef>
    <entries>
      <li>WorkType:PlantCutting</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Miner</defName>
    <label>Miner</label>
    <description>Mining and drilling.</description>
    <colorRef>sky-700</colorRef>
    <entries>
      <li>WorkType:Mining</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Smith</defName>
    <label>Smith</label>
    <description>Weapon and armor smithing.</description>
    <colorRef>amber-700</colorRef>
    <entries>
      <li>WorkType:Smithing</li>
      <!-- Redundant at compile time (Smithing already includes it); listed so
           Fabricator is a literal subset of Smith. -->
      <li>WorkGiver:DoBillsFabricationBench</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Fabricator</defName>
    <label>Fabricator</label>
    <description>Fabricating things at the fabrication bench.</description>
    <colorRef>amber-800</colorRef>
    <entries>
      <li>WorkGiver:DoBillsFabricationBench</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Tailor</defName>
    <label>Tailor</label>
    <description>Apparel creation.</description>
    <colorRef>amber-700</colorRef>
    <entries>
      <li>WorkType:Tailoring</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Artist</defName>
    <label>Artist</label>
    <description>Sculpting and artwork.</description>
    <colorRef>purple-700</colorRef>
    <entries>
      <li>WorkType:Art</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Crafter</defName>
    <label>Crafter</label>
    <description>General crafting: stonecutting, smelting, drugs and components.</description>
    <colorRef>amber-700</colorRef>
    <entries>
      <li>WorkType:Crafting</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Grunt</defName>
    <label>Grunt</label>
    <description>Hauling and cleaning.</description>
    <colorRef>stone-700</colorRef>
    <entries>
      <li>WorkType:Hauling</li>
      <li>WorkType:Cleaning</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Hauler</defName>
    <label>Hauler</label>
    <description>Hauling items.</description>
    <colorRef>stone-800</colorRef>
    <entries>
      <li>WorkType:Hauling</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Cleaner</defName>
    <label>Cleaner</label>
    <description>Cleaning.</description>
    <colorRef>stone-800</colorRef>
    <entries>
      <li>WorkType:Cleaning</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Researcher</defName>
    <label>Researcher</label>
    <description>Research at a research bench.</description>
    <colorRef>slate-700</colorRef>
    <entries>
      <li>WorkType:Research</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef MayRequire="Ludeon.RimWorld.Anomaly">
    <defName>WS_DarkStudier</defName>
    <label>Anomaly Study</label>
    <description>Study of anomalous entities.</description>
    <colorRef>slate-700</colorRef>
    <entries>
      <li>WorkType:DarkStudy</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Firefighter</defName>
    <label>Firefighter</label>
    <description>Fighting fires.</description>
    <colorRef>slate-800</colorRef>
    <entries>
      <li>WorkType:Firefighter</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Patient</defName>
    <label>Patient</label>
    <description>Accepting medical treatment.</description>
    <colorRef>slate-800</colorRef>
    <entries>
      <li>WorkType:Patient</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Bedrest</defName>
    <label>Bedrest</label>
    <description>Resting in bed when ill or injured.</description>
    <colorRef>slate-800</colorRef>
    <entries>
      <li>WorkType:PatientBedRest</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Laborer</defName>
    <label>Laborer</label>
    <description>Miscellaneous simple tasks.</description>
    <colorRef>slate-800</colorRef>
    <entries>
      <li>WorkType:BasicWorker</li>
    </entries>
  </WorkRoles.RoleDef>
</Defs>
