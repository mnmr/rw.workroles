  <WorkRoles.RoleDef>
    <defName>WS_Fabricator</defName>
    <label>Fabricator</label>
    <description>Fabricating things at the fabrication bench.</description>
    <colorRef>amber-800</colorRef>
    <group>Indoors</group>
    <trainSkill>Crafting</trainSkill>
    <trainMinLevel>7</trainMinLevel>
    <entries>
      <li>WorkGiver:DoBillsFabricationBench</li>
    </entries>
  </WorkRoles.RoleDef>

  <WorkRoles.RoleDef>
    <defName>WS_Crafter</defName>
    <label>Crafter</label>
    <description>General crafting: stonecutting, smelting, drugs and components.</description>
    <colorRef>orange-700</colorRef>
    <group>Indoors</group>
    <!-- No band ceiling: the targets supplement rather than cover this role,
         so outgrowing it must not abandon its jobs. -->
    <trainSkill>Crafting</trainSkill>
    <trainTargets>
      <li>WS_DrugMaker</li>
      <li>WS_Smith</li>
      <li>WS_Tailor</li>
      <li>WS_Fabricator</li>
    </trainTargets>
    <minHolders>1</minHolders>
    <entries>
      <li>WorkType:Crafting</li>
    </entries>
  </WorkRoles.RoleDef>

